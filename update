#!/usr/bin/env bash

set -e

TAG=""

# --- argument parsing ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --tag)
      TAG="$2"
      shift 2
      ;;
    *)
      echo "❌ Unknown argument: $1"
      echo "Usage: $0 --tag <tag>"
      exit 1
      ;;
  esac
done

if [[ -z "$TAG" ]]; then
  echo "❌ No tag specified. Usage: $0 --tag <tag>"
  exit 1
fi

# --- execution ---
echo "📥 Fetching tags from upstream..."
git fetch upstream --tags

echo "🔍 Checking out current branch..."
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)

echo "🔁 Rebasing '$CURRENT_BRANCH' onto tag '$TAG'..."
git rebase --onto "tags/$TAG" "$(git merge-base $CURRENT_BRANCH master)"

echo "✅ Rebase completed successfully."
